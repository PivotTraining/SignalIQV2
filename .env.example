# ─────────────────────────────────────────────────────────────────────────────
# Signal IQ v2 — Environment Variables
# Copy to .env.local and fill in your values.
#
# Backend priority:  Supabase → Airtable → Seed data (fallback)
# Only one needs to be configured. Supabase is recommended (free forever).
# ─────────────────────────────────────────────────────────────────────────────

# ── Option A: Supabase (recommended — free forever) ──────────────────────────
# 1. Create a project at https://supabase.com (free)
# 2. Run supabase/schema.sql then supabase/seed.sql in the SQL Editor
# 3. Project Settings → API → copy Project URL and anon/public key

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Set to "false" to disable Supabase and fall through to Airtable/seed
NEXT_PUBLIC_SUPABASE_ENABLED=true

# ── Option B: Airtable ───────────────────────────────────────────────────────
# Get your API token at: https://airtable.com/create/tokens
# Base ID is the first segment of your base URL: airtable.com/appXXXXXXXXXXXXXX

AIRTABLE_API_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table names (must match exactly what you named them in Airtable)
AIRTABLE_CONTACTS_TABLE=Contacts
AIRTABLE_INTERACTIONS_TABLE=Interactions
AIRTABLE_ORGS_TABLE=Organizations

# Set to "true" to use Airtable (only used if NEXT_PUBLIC_SUPABASE_ENABLED is false)
NEXT_PUBLIC_AIRTABLE_ENABLED=false
